# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pragati_agent

# ML Service (FastAPI)
ML_SERVICE_URL=http://localhost:5001

# Meta Llama API (Official Hosted Inference)
LLAMA_API_KEY=your-llama-api-key
LLAMA_MODEL=Llama-3.3-70B-Instruct
LLAMA_API_BASE_URL=https://api.llama.com/compat/v1

# Google Cloud Translation (fallback only)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GOOGLE_PROJECT_ID=your-gcp-project-id

# Twilio (placeholder — not sent in dev)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+10000000000

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
