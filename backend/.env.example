# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pragati_agent

# ML Service (FastAPI)
ML_SERVICE_URL=http://localhost:5001

# Groq AI (required)
# Get your key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
# Optional fallback model (same Groq API key can be used).
# Example: GROQ_FALLBACK_MODEL=llama-3.1-8b
# If your Groq account supports it, you can also try gpt-ovela.
GROQ_FALLBACK_MODEL=llama-3.1-8b
GROQ_API_BASE_URL=https://api.groq.com/openai/v1

# Google Cloud Translation (fallback only — leave blank to skip)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GOOGLE_PROJECT_ID=your-gcp-project-id

# Twilio WhatsApp (placeholder — not sent in dev)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=whatsapp:+14155238886


WHATSAPP_RETRY_INTERVAL_MS=60000
WHATSAPP_RETRY_MAX_ATTEMPTS=10

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
